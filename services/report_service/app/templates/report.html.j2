<!doctype html>
<html lang="ru">
<head>
  <meta charset="utf-8">
  <title>Отчёт по тестированию</title>
  <style>
    @font-face {
      font-family: "DejaVuSans";
      src: url("file:///usr/share/fonts/truetype/dejavu/DejaVuSans.ttf");
    }
    @font-face {
      font-family: "DejaVuSans";
      src: url("file:///usr/share/fonts/truetype/dejavu/DejaVuSans-Bold.ttf");
      font-weight: bold;
    }
    @page { size: A4; margin: 1.5cm; }
    body { font-family: "DejaVuSans", sans-serif; color: #1f2933; font-size: 11pt; }
    h1 { font-size: 18pt; border-bottom: 2px solid #999; padding-bottom: 4pt; margin-bottom: 8pt; }
    h2 { font-size: 13pt; margin-top: 14pt; margin-bottom: 6pt; color: #1d4ed8; }
    .meta { color: #444; font-size: 10pt; margin-bottom: 10pt; line-height: 1.5; }
    .pill { display: inline-block; padding: 2pt 8pt; border-radius: 10pt; background: #d6e4ff; font-weight: bold; font-size: 11pt; }
    .question { border: 1px solid #ccc; border-radius: 4pt; padding: 8pt 10pt; margin-bottom: 8pt; }
    .question .header { font-weight: bold; margin-bottom: 4pt; }
    .question .label { color: #555; font-size: 9pt; text-transform: uppercase; letter-spacing: .3pt; margin-top: 4pt; }
    .question .value { margin-top: 1pt; white-space: pre-wrap; }
    .question .score { float: right; padding: 2pt 6pt; border-radius: 4pt; background: #e2e8f0; font-weight: bold; }
    .reco { border-left: 3pt solid #1d4ed8; padding: 4pt 8pt; margin-bottom: 6pt; background: #f4f7ff; }
    .reco .topic { font-weight: bold; }
    .empty { color: #777; font-style: italic; }
  </style>
</head>
<body>
  <h1>Отчёт по тестированию</h1>
  <div class="meta">
    <div><strong>Тест:</strong> {{ test.title or "—" }}</div>
    {% if test.description %}<div><strong>Описание:</strong> {{ test.description }}</div>{% endif %}
    <div><strong>Участник:</strong> {{ participant.full_name or "—" }}{% if participant.email %} ({{ participant.email }}){% endif %}</div>
    {% if participant.department %}<div><strong>Подразделение:</strong> {{ participant.department }}</div>{% endif %}
    {% if participant.position %}<div><strong>Должность:</strong> {{ participant.position }}</div>{% endif %}
    <div><strong>Дата:</strong> {{ report.created_at.strftime('%Y-%m-%d %H:%M') if report.created_at else "" }}</div>
    <div style="margin-top: 6pt;"><strong>Итоговая оценка:</strong>
      <span class="pill">{{ "%.1f"|format(report.score) }} / 1.0</span>
    </div>
  </div>

  <h2>Ответы по вопросам</h2>
  {% if items %}
    {% for q in items %}
      <div class="question">
        <div class="header">
          <span class="score">{{ "%.1f"|format(q.score) }}</span>
          {{ loop.index }}. {{ q.text }}
        </div>
        <div class="label">Правильный ответ</div>
        <div class="value">{{ q.correct_answer }}</div>
        <div class="label">Ответ пользователя</div>
        <div class="value">{{ q.user_answer or "(нет ответа)" }}</div>
        {% if q.feedback %}
          <div class="label">Комментарий ИИ</div>
          <div class="value">{{ q.feedback }}</div>
        {% endif %}
      </div>
    {% endfor %}
  {% else %}
    <div class="empty">Нет данных по вопросам.</div>
  {% endif %}

  <h2>Рекомендации к изучению</h2>
  {% if recommendations %}
    {% for r in recommendations %}
      <div class="reco">
        <div class="topic">{{ r.topic }}</div>
        <div>{{ r.reason }}</div>
        {% if r.resource_url %}<div>Материалы: {{ r.resource_url }}</div>{% endif %}
      </div>
    {% endfor %}
  {% else %}
    <div class="empty">Рекомендаций нет — результаты в пределах ожиданий.</div>
  {% endif %}
</body>
</html>
