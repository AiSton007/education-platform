# --- Общие ---
APP_ENV=development
LOG_LEVEL=info
METRICS_ENABLED=true

# --- PostgreSQL (одно соединение, разные схемы и пользователи per-сервис) ---
DB_HOST=postgres
DB_PORT=5432
DB_NAME=education
DB_SSL_MODE=disable
DB_MAX_OPEN_CONNS=10
DB_MAX_IDLE_CONNS=2
DB_CONN_MAX_LIFETIME=300

# Пароли per-service (в k8s — через Secret из chart postgresql)
AUTH_DB_USER=auth_user
AUTH_DB_PASSWORD=auth_pass_change_me
USER_DB_USER=users_user
USER_DB_PASSWORD=users_pass_change_me
TEST_DB_USER=tests_user
TEST_DB_PASSWORD=tests_pass_change_me
LLM_DB_USER=llm_user
LLM_DB_PASSWORD=llm_pass_change_me
REPORT_DB_USER=reports_user
REPORT_DB_PASSWORD=reports_pass_change_me

# --- JWT (user-facing) ---
JWT_SECRET=dev-please-rotate-in-secret
JWT_ACCESS_TOKEN_TTL=900
JWT_REFRESH_TOKEN_TTL=604800

# --- Internal service-to-service JWT ---
INTERNAL_JWT_SECRET=dev-internal-please-rotate
INTERNAL_JWT_TTL=300

# --- Service URLs (для api-gateway и оркестрации test-service'ом) ---
AUTH_SERVICE_URL=http://auth-service:8080
USER_SERVICE_URL=http://user-service:8080
TEST_SERVICE_URL=http://test-service:8080
LLM_SERVICE_URL=http://llm-service:8080
REPORT_SERVICE_URL=http://report-service:8080

# --- LLM (GigaChat) ---
# mock — офлайн без API; gigachat — реальная нейросеть Сбера
LLM_PROVIDER=gigachat
LLM_API_URL=https://gigachat.devices.sberbank.ru/api/v1
LLM_OAUTH_URL=https://ngw.devices.sberbank.ru:9443/api/v2/oauth
LLM_OAUTH_SCOPE=GIGACHAT_API_PERS
# Authorization Key из личного кабинета developers.sber.ru (шаг 1: Basic auth для OAuth)
LLM_API_KEY=
LLM_MODEL=GigaChat
LLM_TIMEOUT_SECONDS=30
# true — нужен сертификат НУЦ Минцифры; false — только для локальной отладки
LLM_VERIFY_SSL=true
# Путь к PEM bundle НУЦ Минцифры (опционально; в k8s — ConfigMap mount)
# LLM_CA_BUNDLE=/etc/ssl/mincifry/ca-bundle.crt

# Таймаут test-service → llm-service при submit (секунды, >= LLM_TIMEOUT_SECONDS)
LLM_ANALYZE_TIMEOUT_SECONDS=90
